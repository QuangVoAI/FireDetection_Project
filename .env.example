# ============================================================
# 🔐 Biến môi trường — CẤM push file .env lên Git!
# ============================================================
# Copy file này thành .env và điền API keys của bạn.
# ============================================================

# --- Weights & Biases (WandB) ---
# Dùng để theo dõi biểu đồ training online. Lấy tại: https://wandb.ai/settings
WANDB_API_KEY=your_wandb_api_key_here

# --- Roboflow ---
# Dùng để tải dataset tự động. Lấy tại: https://roboflow.com/
ROBOFLOW_API_KEY=your_roboflow_key_here

# --- Telegram (Tùy chọn) ---
# Dùng để nhận cảnh báo qua tin nhắn.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
