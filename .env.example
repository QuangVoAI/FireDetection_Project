# ──────────────────────────────────────────────
# Template – copy this file to .env and fill in
# your own secrets.  Never commit the real .env.
# ──────────────────────────────────────────────

# ── Telegram Bot ───────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Twilio (SMS / Voice call) ──────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+84xxxxxxxxx
TWILIO_TO_NUMBER=+84xxxxxxxxx
TWILIO_PCCC_NUMBER=+84xxxxxxxxx

# ── Zalo OA ────────────────────────────────────
ZALO_ACCESS_TOKEN=your_zalo_oa_access_token_here
ZALO_USER_ID=your_zalo_user_id_here

# ── Vietmap API ────────────────────────────────
VIETMAP_API_KEY=your_vietmap_api_key_here

# ── Alert thresholds ───────────────────────────
# Minimum confidence score to trigger alert
ALERT_CONFIDENCE_THRESHOLD=0.45
# Number of consecutive detections before firing alert
ALERT_CONSECUTIVE_FRAMES=3

# ── Camera / Video source ──────────────────────
# 0  = default webcam, or an RTSP / HTTP stream URL
VIDEO_SOURCE=0
# GPS coordinates of the camera (fill manually or integrate GPS module)
CAMERA_LATITUDE=10.7769
CAMERA_LONGITUDE=106.7009
CAMERA_ADDRESS=123 Nguyen Van Linh, Quan 7, TP.HCM

# ── Model ──────────────────────────────────────
MODEL_WEIGHTS=models/weights/best.pt
