# ============================================================
# 🔐 Biến môi trường — CẤM push file .env lên Git!
# ============================================================
# Copy file này thành .env và điền API keys của bạn:
#   cp .env.example .env
# ============================================================

# --- Telegram Bot ---
# Tạo bot tại: https://t.me/BotFather
# Lấy chat_id: gửi tin nhắn cho bot, rồi truy cập
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Twilio (SMS/Voice) ---
# Đăng ký tại: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBERS=+84901234567,+84909876543

# --- Zalo OA ---
# Tạo OA tại: https://oa.zalo.me/
ZALO_ACCESS_TOKEN=your_zalo_access_token_here
ZALO_USER_ID=your_zalo_user_id_here

# --- Vietmap API (Geocoding) ---
# Đăng ký tại: https://maps.vietmap.vn/
VIETMAP_API_KEY=your_vietmap_api_key_here
